#!/command/with-contenv bash
# VNC display stack (:0 / :5901 / :6080); runs as sandbox user.
if command -v s6-setuidgid >/dev/null 2>&1; then
  exec s6-setuidgid user /entrypoint-vnc.sh
fi
if command -v runuser >/dev/null 2>&1; then
  exec runuser -u user -- /entrypoint-vnc.sh
fi
exec su -s /bin/bash user -c 'exec /entrypoint-vnc.sh'
