# Pi 配置
# 使用前复制为 pi.env 并填写密钥：
#   cp config/pi.env.example config/pi.env
#
# config/pi.env 已加入 .gitignore，请勿提交密钥。
# TEAM_API_KEY / TEAM_BASE_URL / TEAM_MODEL 会在容器启动时注入，不会写入镜像构建层。

# --- 必填 ---

# OpenAI 兼容 API Key
TEAM_API_KEY=

# --- API / 模型 ---

TEAM_BASE_URL=https://claude-code.club/openai/v1
TEAM_MODEL=gpt-5.5

# --- Areal bridge（启动时注入 models.json 顶层 areal 字段）---

# 写入 areal.headers.X-Bridge-User-Id
BRIDGE_USER_ID=

# 以下为 areal 默认值，一般无需修改
AREAL_BASE_URL=http://10.110.158.143:9100/v1
# AREAL_API=openai-completions
# AREAL_API_KEY=bridge

# --- Pi Suite（构建时使用，非密钥）---

PI_SUITE_VERSION=0.1.17
PI_SUITE=npm:@lebronj/pi-suite
PI_WORKSPACE_DIR=/workspace

# --- Memory Evolution（可选，构建时使用）---

PI_EVOLUTION_ENABLED=1

# 设为 0 可跳过 Pi 安装
INSTALL_PI=1

# --- Pi Web Console（容器内 6079，宿主可通过 PI_WEB_HOST_PORT 映射）---

PI_WEB_HOST_PORT=6079
# PI_WEB_WORKSPACE=/workspace

# npm 镜像（国内构建网络超时时建议启用）
NPM_REGISTRY=https://registry.npmmirror.com

# --- Multica daemon（启动时注入）---

MULTICA_SERVER_URL=http://10.110.158.143:8081
MULTICA_APP_URL=http://10.110.158.143:3001
MULTICA_WORKSPACE_ID=f1b514db-54f1-48ec-b1a7-a5ac6d128977
MULTICA_TOKEN=

# 可选：命名 profile 会写到 ~/.multica/profiles/<name>/config.json
MULTICA_PROFILE=

# 设为 0 可禁用容器内 Multica daemon
MULTICA_DAEMON_ENABLED=1
