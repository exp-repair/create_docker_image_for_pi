# Pi 配置
# 使用前复制为 pi.env 并填写密钥：
#   cp config/pi.env.example config/pi.env
#
# config/pi.env 已加入 .gitignore，请勿提交密钥。
# TEAM_API_KEY / TEAM_BASE_URL / TEAM_MODEL 会在容器启动时注入，不会写入镜像构建层。

# --- 必填 ---

# OpenAI 兼容 API Key
TEAM_API_KEY=

# --- API / 模型 ---

TEAM_BASE_URL=https://claude-code.club/openai/v1
TEAM_MODEL=gpt-5.5

# --- Pi Suite（构建时使用，非密钥）---

PI_SUITE_VERSION=0.1.17
PI_SUITE=npm:@lebronj/pi-suite
PI_WORKSPACE_DIR=/workspace

# --- Memory Evolution（可选，构建时使用）---

PI_EVOLUTION_ENABLED=1

# 设为 0 可跳过 Pi 安装
INSTALL_PI=1

# npm 镜像（国内构建网络超时时建议启用）
NPM_REGISTRY=https://registry.npmmirror.com
